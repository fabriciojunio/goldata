# Banco de Dados
DB_USER=goldata
DB_PASSWORD=TROQUE_POR_SENHA_FORTE
DATABASE_URL=postgresql+asyncpg://${DB_USER:-goldata}:${DB_PASSWORD}@localhost:5432/goldata

# API (gere com: openssl rand -hex 32)
SECRET_KEY=TROQUE_POR_CHAVE_ALEATORIA
API_KEY=TROQUE_POR_API_KEY_ALEATORIA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
